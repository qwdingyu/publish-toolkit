{
  "name": "@usethink/publish-toolkit",
  "version": "0.1.1",
  "description": "统一 npm 包发布工具链 — 混淆构建、包准备、一键发布",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "publish-toolkit": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
